{
  "name": "PIDME — BUAL 5860",
  "image": "mcr.microsoft.com/devcontainers/python:3.12",
  "postCreateCommand": "pip install -r src/requirements.txt",
  "postStartCommand": "cd src && python main.py",
  "forwardPorts": [8000],
  "portsAttributes": {
    "8000": {
      "label": "PIDME Dashboard",
      "onAutoForward": "openBrowserOnce",
      "visibility": "public"
    }
  },
  "customizations": {
    "vscode": {
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python"
      },
      "extensions": [
        "ms-python.python"
      ]
    }
  }
}
